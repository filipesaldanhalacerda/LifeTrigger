{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://lifetrigger-auth.onrender.com/api/v1/:path*"
    },
    {
      "source": "/api/engine/:path*",
      "destination": "https://lifetrigger-engine.onrender.com/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
