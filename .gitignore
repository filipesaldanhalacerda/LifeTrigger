# ═══════════════════════════════════════════════════════════════════════
# LifeTriggerEngine — .gitignore
# Monorepo: .NET (Engine + Auth API) + Node.js/Vite (Frontend)
# ═══════════════════════════════════════════════════════════════════════

# ── .NET / Visual Studio ────────────────────────────────────────────────

# User-specific IDE files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build output
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
Generated\ Files/
*.VisualState.xml

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml

# NuGet packages (restored on build — never committed)
*.nupkg
*.snupkg
.nuget/
packages/

# JetBrains Rider
.idea/
*.sln.iml

# ── ASP.NET Core — configs com credenciais ──────────────────────────────
# appsettings.Development.json é versionado intencionalmente para que todos
# os devs compartilhem a mesma config de desenvolvimento (DB local + Supabase dev).
# Para overrides pessoais use appsettings.Local.json (ignorado abaixo).
appsettings.Local.json
appsettings.*.local.json
secrets.json

# ── Node.js / Frontend ──────────────────────────────────────────────────

# Dependências — nunca versionadas, restauradas via npm install
node_modules/

# Build output do Vite
dist/
.vite/

# Cache de ferramentas
.cache/
.parcel-cache/

# ── Variáveis de ambiente ────────────────────────────────────────────────
# NUNCA commitar arquivos .env com valores reais
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Certificados e chaves privadas ──────────────────────────────────────
*.pfx
*.p12
*.key
*.pem
*.cer
*.crt

# ── Logs ────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Sistema Operacional ─────────────────────────────────────────────────

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
desktop.ini

# ── Misc ────────────────────────────────────────────────────────────────
.gemini/
